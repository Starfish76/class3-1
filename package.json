{
    "name":  "class-memory-homepage",
    "private":  true,
    "version":  "0.0.0",
    "type":  "module",
    "engines":  {
                    "node":  "\u003e=20.19.0 \u003c21 || \u003e=22.12.0 \u003c23"
                },
    "scripts":  {
                    "dev":  "vite",
                    "build":  "node -e \"const [major,minor]=process.versions.node.split(\u0027.\u0027).map(Number); const ok=(major===20\u0026\u0026minor\u003e=19)||(major===22\u0026\u0026minor\u003e=12); if(!ok){console.error(\u0027Unsupported Node.js version: \u0027+process.versions.node+\u0027. Use Node 20.19+ or 22.12+ (LTS).\u0027); process.exit(1)}\" \u0026\u0026 tsc -b \u0026\u0026 vite build",
                    "lint":  "eslint .",
                    "preview":  "vite preview",
                    "deploy":  "node -e \"const [major,minor]=process.versions.node.split(\u0027.\u0027).map(Number); const ok=(major===20\u0026\u0026minor\u003e=19)||(major===22\u0026\u0026minor\u003e=12); if(!ok){console.error(\u0027Unsupported Node.js version: \u0027+process.versions.node+\u0027. Use Node 20.19+ or 22.12+ (LTS).\u0027); process.exit(1)}\" \u0026\u0026 tsc -b \u0026\u0026 vite build \u0026\u0026 gh-pages -d dist"
                },
